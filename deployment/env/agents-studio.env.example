# Service binding
HOST=127.0.0.1
PORT=8765

# Paths
SOURCE_ROOT=/opt/agents-production-studio
OUTPUT_DIR=/var/lib/agents-production-studio

# Admin token for model configuration write operations
AGENTS_ADMIN_TOKEN=change-this-admin-token

# Optional default model runtime
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional: disable Codex-provided defaults
AGENTS_WORKFLOW_DISABLE_CODEX_CONFIG=0
