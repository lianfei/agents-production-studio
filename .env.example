# Optional admin token for model configuration write operations.
AGENTS_ADMIN_TOKEN=change-this-admin-token

# Optional default OpenAI-compatible model configuration.
# Leave blank if you want to run the app without model enhancement.
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional: disable any Codex-provided default model discovery.
AGENTS_WORKFLOW_DISABLE_CODEX_CONFIG=0
